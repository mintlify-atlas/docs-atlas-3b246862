  "keyFeatures": [
    "Virtual DOM with efficient diffing algorithm",
    "Class-based and functional components",
    "React-like hooks API (useState, useEffect, useMemo, useCallback)",
    "Global state management with createStore and connect",
    "Lazy loading and code splitting with Suspense",
    "Slots for content projection",
    "Component lifecycle hooks",
    "Event handling with automatic cleanup"
  ],
  "publicApiSurface": [
    "h(tag, props, children)",
    "hFragment(children)",
    "hString(string)",
    "createApp(config)",
    "Component",
    "createComponent(component, props)",
    "useState(initialState)",
    "useEffect(effectFn, deps)",
    "useRef(initialValue)",
    "useMemo(computeFn, deps)",
    "useCallback(callbackFn, deps)",
    "createStore(initialState, actions)",
    "connect(store, selector)",
    "createActions(store, actions)",
    "lazy(importFn)",
    "Suspense",
    "createSlot(name)",
    "createSlotContent(name, content)"
  ]
}
